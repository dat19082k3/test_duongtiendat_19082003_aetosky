{
  "name": "job-processing-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:backend": "cd backend && . venv/bin/activate && uvicorn main:app --reload --port 8000",
    "dev:frontend": "cd frontend && npm run dev",
    "dev": "concurrently -c \"blue.bold,green.bold\" -n \"backend,frontend\" \"npm run dev:backend\" \"npm run dev:frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
